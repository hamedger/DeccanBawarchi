# ── Server ──
PORT=3001
NODE_ENV=production

# Comma-separated origins allowed for browser requests (include localhost for dev)
CORS_ALLOWED_ORIGINS=https://deccanbawarchi.com,https://www.deccanbawarchi.com,http://localhost:8081

# ── Firebase Admin (Render: paste full service account JSON as one line) ──
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Or local dev only:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ── Clover Hosted Checkout (production) ──
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_TIPS_ENABLED=false
CLOVER_SUCCESS_URL=https://deccanbawarchi.com/checkout/success
CLOVER_FAILURE_URL=https://deccanbawarchi.com/checkout

# Option A (recommended on Render): one JSON env var for all locations
# Keys must match app location IDs: northville-mi, farmington-hills-mi
CLOVER_LOCATIONS_JSON={"northville-mi":{"merchantId":"MERCHANT_ID_1","privateKey":"PRIVATE_KEY_1","webhookSecret":"WEBHOOK_SECRET_1"},"farmington-hills-mi":{"merchantId":"MERCHANT_ID_2","privateKey":"PRIVATE_KEY_2","webhookSecret":"WEBHOOK_SECRET_2"}}

# Option B: separate env vars per location (hyphens become underscores, uppercased)
# CLOVER_LOCATION_NORTHVILLE_MI_MERCHANT_ID=
# CLOVER_LOCATION_NORTHVILLE_MI_PRIVATE_KEY=
# CLOVER_LOCATION_NORTHVILLE_MI_WEBHOOK_SECRET=
# CLOVER_LOCATION_FARMINGTON_HILLS_MI_MERCHANT_ID=
# CLOVER_LOCATION_FARMINGTON_HILLS_MI_PRIVATE_KEY=
# CLOVER_LOCATION_FARMINGTON_HILLS_MI_WEBHOOK_SECRET=

# Option C (legacy single location only):
# CLOVER_MERCHANT_ID=
# CLOVER_PRIVATE_KEY=
# CLOVER_WEBHOOK_SECRET=
# CLOVER_DEFAULT_LOCATION_ID=northville-mi
