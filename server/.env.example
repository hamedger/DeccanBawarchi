# ── Server ──
PORT=3001
NODE_ENV=production

# Comma-separated origins allowed for browser requests (include localhost for dev)
CORS_ALLOWED_ORIGINS=https://deccanbawarchi.com,https://www.deccanbawarchi.com,http://localhost:8081,http://localhost:8082

# Local dev with Auth emulator (npm run dev) — verifies emulator ID tokens
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_PROJECT_ID=deccanbawarchi-d04cc

# ── Firebase Admin (Render: paste full service account JSON as one line) ──
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Or local dev only:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ── Clover Hosted Checkout (production) ──
CLOVER_API_BASE_URL=https://api.clover.com
CLOVER_TIPS_ENABLED=false
# Post-payment redirect (HTTPS required). Dashboard Redirect URLs OVERRIDE these API values —
# use the same URL in Clover Hosted Checkout settings, or leave dashboard blank.
# Home page success URL (include session_id placeholder in Clover dashboard):
#   https://www.deccanbawarchi.com/?session_id={CHECKOUT_SESSION_ID}
CLOVER_SITE_URL=https://www.deccanbawarchi.com
CLOVER_SUCCESS_URL=https://www.deccanbawarchi.com/
CLOVER_FAILURE_URL=https://www.deccanbawarchi.com/checkout

# Option A (recommended on Render): one JSON env var for all locations
# Keys must match app location IDs: northville-mi, farmington-hills-mi
# webhookSecret MUST match Hosted Checkout → Signing Secret in Clover Dashboard (per page).
# If each location has its own Hosted Checkout page, each may have a different signing secret.
CLOVER_LOCATIONS_JSON={"northville-mi":{"merchantId":"MERCHANT_ID_1","privateKey":"PRIVATE_KEY_1","webhookSecret":"WEBHOOK_SECRET_1"},"farmington-hills-mi":{"merchantId":"MERCHANT_ID_2","privateKey":"PRIVATE_KEY_2","webhookSecret":"WEBHOOK_SECRET_2"}}

# Option B: separate env vars per location (hyphens become underscores, uppercased)
# CLOVER_LOCATION_NORTHVILLE_MI_MERCHANT_ID=
# CLOVER_LOCATION_NORTHVILLE_MI_PRIVATE_KEY=
# CLOVER_LOCATION_NORTHVILLE_MI_WEBHOOK_SECRET=
# CLOVER_LOCATION_FARMINGTON_HILLS_MI_MERCHANT_ID=
# CLOVER_LOCATION_FARMINGTON_HILLS_MI_PRIVATE_KEY=
# CLOVER_LOCATION_FARMINGTON_HILLS_MI_WEBHOOK_SECRET=

# Option C (legacy single location only):
# CLOVER_MERCHANT_ID=
# CLOVER_PRIVATE_KEY=
# CLOVER_WEBHOOK_SECRET=
# CLOVER_DEFAULT_LOCATION_ID=northville-mi

# ── Resend (staff order notification emails from Clover webhook) ──
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=orders@deccanbawarchi.com
# ORDERS_NOTIFICATION_EMAIL=mjalaluddin63@gmail.com
