# ─────────────────────────────────────────────
# Deccan Bawarchi — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — only .env.example
# ─────────────────────────────────────────────

# ── Firebase (client-safe — EXPO_PUBLIC_ prefix required) ──
# Firestore uses this project — get values from Firebase Console → Project settings → Your apps
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy_YOUR_KEY_HERE
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123def456
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Staff admin (optional default email on login form) ──
EXPO_PUBLIC_ADMIN_EMAIL=admin@deccanbawarchi.com
# Dev only: allow login before admin custom claim is set (menu/order writes may still fail)
# EXPO_PUBLIC_ADMIN_SKIP_CLAIM=true

# Revenue tab — separate password so staff can use admin without seeing financials
EXPO_PUBLIC_ADMIN_REVENUE_PASSWORD=your-revenue-password

# ── Firestore ──
EXPO_PUBLIC_FIRESTORE_DATABASE_ID=(default)
# Server scripts (seed, setAdminClaim) — path to Firebase service account JSON
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/deccanbawarchi-firebase-adminsdk.json

# Functions emulator (DoorDash quotes, etc.) — requires: npm run functions:serve:doordash
EXPO_PUBLIC_USE_FUNCTIONS_EMULATOR=true
EXPO_PUBLIC_FUNCTIONS_EMULATOR_HOST=127.0.0.1
EXPO_PUBLIC_FUNCTIONS_EMULATOR_PORT=5001
# Auth emulator (9099) — only when emulators are running; else uses production Firebase Auth
# EXPO_PUBLIC_USE_AUTH_EMULATOR=true
EXPO_PUBLIC_AUTH_EMULATOR_PORT=9099

# DoorDash delivery UI — set true for local/staging smoke tests (off in prod until go-live)
# EXPO_PUBLIC_DELIVERY_ENABLED=true

# ── Render API (Clover Hosted Checkout backend) ──
# Production / staging only. When EXPO_PUBLIC_USE_FUNCTIONS_EMULATOR=true the app uses http://localhost:3001.
EXPO_PUBLIC_API_URL=https://deccanbawarchi-api.onrender.com

# ── Stripe (publishable key is client-safe) ──
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY

# ── Google Places (for address autocomplete) ──
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# ── Expo EAS ──
EXPO_PROJECT_ID=your-eas-project-id
