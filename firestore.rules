rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdminEmail() {
      return request.auth != null && request.auth.token.email in [
        'deccanbawarchi7@gmail.com',
        'admin@deccanbawarchi.com',
      ];
    }
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true || isAdminEmail()
      );
    }
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users — own document only
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Menu — public read, admin write
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Buffet — public read, admin write
    match /buffet/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — authenticated create/read own, admin all
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }

    // Reviews — public read, authenticated create (1 per orderItem)
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // Promos — public read, admin write
    match /promos/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reservations — public create with required fields, admin manage
    match /reservations/{reservationId} {
      allow create: if request.resource.data.keys().hasAll([
          'name', 'email', 'phone', 'partySize', 'date', 'time', 'status', 'locationId'
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.partySize is int
        && request.resource.data.partySize >= 1
        && request.resource.data.partySize <= 20
        && request.resource.data.status == 'pending';
      allow read, update: if isAdmin()
        || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Catering inquiries — public create with required fields, admin read
    match /catering_inquiries/{docId} {
      allow create: if request.resource.data.keys().hasAll([
          'name', 'email', 'phone', 'eventDate', 'headcount', 'status'
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.headcount is int
        && request.resource.data.headcount >= 10
        && request.resource.data.status == 'pending';
      allow read: if isAdmin();
    }

    // Locations — public read, admin write
    match /locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // AI growth insights — admin read only, Cloud Functions write
    match /admin_insights/{locationId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
